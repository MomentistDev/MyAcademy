PORT=4000
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: allow x-user-id without JWT (local tooling only).
# Role and organization are still resolved from memberships in the database.
# ALLOW_AUTH_DEV_HEADERS=1

# Next.js app (web/.env.local) — use Publishable key only in the browser.
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# Optional transactional email (nodemailer). If SMTP_HOST is unset, email is skipped.
# This repo enables Inbucket SMTP in supabase/config.toml (smtp_port = 54325). After `supabase start`,
# point the API here so staff/learner onboarding emails appear in the same UI as invite mail (web UI port 54324).
# SMTP_HOST=127.0.0.1
# SMTP_PORT=54325
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=MyAcademy <noreply@localhost>
# Other stacks (e.g. Mailpit alone) often use SMTP_PORT=1025 instead.

# --- CHIP Collect (https://www.chip-in.asia/collect) — optional billing ---
# API base: https://docs.chip-in.asia/chip-collect/overview/introduction
# CHIP_COLLECT_GATEWAY_BASE_URL=https://gate.chip-in.asia/api/v1
# CHIP_COLLECT_API_KEY=
# CHIP_COLLECT_BRAND_ID=
# Amounts are smallest currency units (e.g. 100 = RM 1.00 when currency is MYR).
# CHIP_COLLECT_PRICE_GROWTH_CENTS=29900
# CHIP_COLLECT_PRICE_ENTERPRISE_CENTS=99900
# CHIP_COLLECT_CURRENCY=MYR
# Used to build success_redirect / failure_redirect for purchases.
# PUBLIC_WEB_APP_URL=http://localhost:3000
# PEM public key for webhook signature verification (see Authentication in CHIP docs).
# CHIP_COLLECT_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----"
# Local tests only — never enable in production:
# CHIP_COLLECT_WEBHOOK_SKIP_SIGNATURE_VERIFY=0
